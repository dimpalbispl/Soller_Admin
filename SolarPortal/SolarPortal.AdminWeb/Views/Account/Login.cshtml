@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="brand-logo-lg">☀️</div>
        <h1 class="auth-title">SOLAR PORTAL</h1>
        <p class="auth-sub">Sign in to your account</p>
    </div>

    <form asp-action="Login" method="post" id="loginForm">
        <input type="hidden" asp-for="ReturnUrl" />
        <div class="fg">
            <label asp-for="Email">Username</label>
            <input asp-for="Email" type="text" placeholder="Your admin username" autocomplete="username" />
            <span asp-validation-for="Email" class="text-danger" style="font-size:11px"></span>
        </div>
        <div class="fg">
            <label asp-for="Password">Password</label>
            <div class="ig">
                <input asp-for="Password" type="password" placeholder="Enter password" id="passwordInput" />
                <button type="button" class="pass-toggle" onclick="togglePass()">👁</button>
            </div>
            <span asp-validation-for="Password" class="text-danger" style="font-size:11px"></span>
        </div>
        <div class="fg" style="display:flex;justify-content:space-between;align-items:center">
            <label style="display:flex;gap:7px;align-items:center;cursor:pointer;margin-bottom:0">
                <input asp-for="RememberMe" type="checkbox" style="width:auto" />
                <span style="font-size:12px;color:var(--text2)">Remember me</span>
            </label>
            <a asp-action="ForgotPassword" style="font-size:12px;color:var(--sun)">Forgot password?</a>
        </div>
        <button type="submit" class="btn btn-p btn-full" style="margin-top:4px">
            ☀️ Sign In
        </button>
    </form>

    @* <div style="text-align:center;margin-top:20px;font-size:13px;color:var(--text3)">
        Don't have an account?
        <a asp-action="Register" style="color:var(--sun)">Register here</a>
    </div>

    <div class="demo-creds">
        <div style="font-size:11px;color:var(--text3);margin-bottom:6px">Demo Credentials:</div>
        <div style="font-size:11px;display:flex;gap:12px;flex-wrap:wrap">
            <span>👤 user@solarportal.com / User@1234</span>
            <span>🛡️ admin@solarportal.com / Admin@1234</span>
        </div>
    </div> *@
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass() {
            const input = document.getElementById('passwordInput');
            input.type = input.type === 'password' ? 'text' : 'password';
        }
    </script>
}