@model ForgotPasswordViewModel
@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<div class="auth-card">
    <div class="auth-logo">
        <div class="brand-logo-lg">☀️</div>
        <h1 class="auth-title">SOLAR PORTAL</h1>
        <p class="auth-sub">Reset your password</p>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="alert alert-s">
            <span class="ai">✅</span> @TempData["Message"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-e">
            <span class="ai">⚠</span> @TempData["Error"]
        </div>
    }

    <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm">
        <div class="fg">
            <label asp-for="Email">Email Address</label>
            <input asp-for="Email" type="email" placeholder="Enter your email address" autocomplete="email" />
            <span asp-validation-for="Email" class="text-danger" style="font-size:11px"></span>
        </div>
        <button type="submit" class="btn btn-p btn-full" style="margin-top:4px">
            📧 Send Reset Link
        </button>
    </form>

    <div style="text-align:center;margin-top:20px;font-size:13px;color:var(--text3)">
        Remember your password?
        <a asp-action="Login" style="color:var(--sun)">Sign in here</a>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}