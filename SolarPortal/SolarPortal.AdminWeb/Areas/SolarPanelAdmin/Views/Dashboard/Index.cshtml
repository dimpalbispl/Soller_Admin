@model AdminDashboardDto
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="page active">
    <div class="ph">
        <div class="ph-bc">🛡️ Admin / <span>Dashboard</span></div>
        <div class="ph-title">Admin Dashboard</div>
        <div class="ph-sub">Manage all solar connection requests and operations</div>
    </div>

    <!-- Stats -->
    <div class="g4" style="margin-bottom:18px">
        <div class="sc">
            <div class="sc-flex">
                <div>
                    <div class="sc-label">Total Projects</div>
                    <div class="sc-val gold">@Model.TotalProjects</div>
                    <div class="sc-sub">All applications</div>
                </div>
                <div class="sc-icon ic-gold">🏗️</div>
            </div>
        </div>
        <div class="sc">
            <div class="sc-flex">
                <div>
                    <div class="sc-label">Pending Payment Verifications</div>
                    <div class="sc-val red">@Model.PendingApprovals</div>
                    <div class="sc-sub">Awaiting payment review</div>
                </div>
                <div class="sc-icon ic-red" style="font-weight:700">₹</div>
            </div>
        </div>
        <div class="sc">
            <div class="sc-flex">
                <div>
                    <div class="sc-label">Active Installations</div>
                    <div class="sc-val blue">@Model.ActiveInstallations</div>
                    <div class="sc-sub">In progress</div>
                </div>
                <div class="sc-icon ic-blue">🔧</div>
            </div>
        </div>
        <div class="sc">
            <div class="sc-flex">
                <div>
                    <div class="sc-label">Total Revenue</div>
                    <div class="sc-val green">₹@Model.TotalRevenue.ToString("N0")</div>
                    <div class="sc-sub">Verified payments</div>
                </div>
                <div class="sc-icon ic-green">📈</div>
            </div>
        </div>
    </div>

    <div class="g2">
        <!-- Recent Requests -->
        <div class="card">
            <div class="ct"><span class="ct-dot"></span>Recent Applications</div>
            <div class="tbl-wrap">
                <table>
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Applicant</th>
                            <th>Plan</th>
                            <th>Type</th>
                            <th>Stage</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @* Per spec: separate Approval module removed.
                           Approve/Reject buttons are gone from this list — all
                           decisions now happen on the Payment Verification page,
                           which is the single source of truth. The table here is
                           informational only. *@
                        @foreach (var r in Model.RecentRequests)
                        {
                            <tr>
                                <td class="td-b">
                                    <a asp-area="SolarPanelAdmin" asp-controller="Projects" asp-action="Details"
                                       asp-route-id="@r.Id" style="color:var(--sun)">@r.RequestNumber</a>
                                </td>
                                <td>@r.ApplicantName</td>
                                <td><partial name="_PlanCell" model="r" /></td>
                                <td>@r.ConnectionType</td>
                                <td>@r.CurrentStage.ToString().Replace("_", " ")</td>
                                <td>
                                    <span class="sts @GetStatusClass(r.ApprovalStatus)">
                                        @r.ApprovalStatus
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="btn-row">
                @* Per spec: Approval module merged into Payment Verification.
                   The dashboard CTA now jumps to Payments/Index instead of the
                   legacy Projects/Approvals page. *@
                <a asp-area="SolarPanelAdmin" asp-controller="Payments" asp-action="Index" class="btn btn-primary">
                    💰 Open Payment Verification (@Model.PendingApprovals)
                </a>
            </div>
        </div>

        <!-- Stage Distribution -->
        <div class="card">
            <div class="ct"><span class="ct-dot"></span>Project Stage Distribution</div>
            @foreach (var kv in Model.StatusDistribution.OrderByDescending(x => x.Value).Take(8))
            {
                var pct = Model.TotalProjects > 0 ? (int)((double)kv.Value / Model.TotalProjects * 100) : 0;
                var color = StageColor(kv.Key);
                var icon = StageIcon(kv.Key);
                <div style="margin-bottom:15px">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:6px">
                        <span style="display:flex;align-items:center;gap:9px;font-size:13px;color:var(--text1);font-weight:500">
                            <span style="width:26px;height:26px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:14px;background:@(color)1a">@icon</span>
                            @kv.Key.Replace("_", " ")
                        </span>
                        <span style="display:flex;align-items:center;gap:8px">
                            <span style="font-size:11px;color:var(--text3)">@pct%</span>
                            <span style="background:@color;color:#fff;font-size:11px;font-weight:700;padding:2px 10px;border-radius:999px;min-width:26px;text-align:center">@kv.Value</span>
                        </span>
                    </div>
                    <div class="prog-wrap">
                        <div class="prog-bar" data-width="@pct" style="width:0;background:@color"></div>
                    </div>
                </div>
            }

            <div class="btn-row">
                <a asp-area="SolarPanelAdmin" asp-controller="Projects" asp-action="Index" class="btn btn-s">
                    View All Projects →
                </a>
            </div>
        </div>
    </div>
</div>

@using SolarPortal.Domain.Enums
@functions {
    string GetStatusClass(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Pending => "sts-pend",
        ApprovalStatus.Approved => "sts-act",
        ApprovalStatus.Rejected => "sts-rej",
        _ => "sts-pend"
    };

    // Distinct colour per workflow stage so the distribution reads at a glance.
    string StageColor(string stage) => stage switch
    {
        "Registration"      => "#64748b",
        "ProductSelection"  => "#6366f1",
        "Payment"           => "#f59e0b",
        "PMSurvey"          => "#0d9488",
        "MeterDispatch"     => "#2563eb",
        "SiteSurvey"        => "#a855f7",
        "MaterialDispatch"  => "#f97316",
        "Installation"      => "#059669",
        "DCRUpdate"         => "#06b6d4",
        "Completed"         => "#16a34a",
        _                   => "#64748b"
    };

    string StageIcon(string stage) => stage switch
    {
        "Registration"      => "📝",
        "ProductSelection"  => "🛒",
        "Payment"           => "💳",
        "PMSurvey"          => "📋",
        "MeterDispatch"     => "⚡",
        "SiteSurvey"        => "📐",
        "MaterialDispatch"  => "📦",
        "Installation"      => "🔧",
        "DCRUpdate"         => "📄",
        "Completed"         => "✅",
        _                   => "📌"
    };
}