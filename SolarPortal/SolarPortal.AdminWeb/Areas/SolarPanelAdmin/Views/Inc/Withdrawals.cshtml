@model List<SolarPortal.Domain.Entities.IncWithdrawal>
@{
    ViewData["Title"] = "INC Withdrawals";
    var workers = ViewBag.Workers as Dictionary<int,string> ?? new();
    string curStatus = ViewBag.Status as string ?? "";
    string Badge(string s) => s == "Approved" ? "success" : s == "Rejected" ? "danger" : "warning";
}
<div class="page-header" style="padding:16px">
    <h2>INC Withdrawals</h2>
    <p class="text-muted">Approve or reject installer withdrawal requests.</p>
</div>
<div class="container-fluid">
    <form method="get" class="mb-3">
        <select name="status" class="form-select form-select-sm" style="width:auto;display:inline-block" onchange="this.form.submit()">
            <option value="">All Status</option>
            @foreach (var s in new[]{"Pending","Approved","Rejected"}) { <option value="@s" selected="@(curStatus==s)">@s</option> }
        </select>
    </form>
    <div class="card">
        <div class="card-header">Withdrawal Requests (@Model.Count)</div>
        <div class="card-body">
            @Html.AntiForgeryToken()
            @if (!Model.Any()) { <p class="text-muted">No withdrawal requests found.</p> }
            else
            {
                <div class="table-responsive"><table class="table table-hover align-middle">
                    <thead><tr><th>Req #</th><th>Installer</th><th style="text-align:right">Amount</th><th>Bank / UPI</th><th>Requested</th><th>Status</th><th>Action</th></tr></thead>
                    <tbody>
                    @foreach (var w in Model)
                    {
                        <tr>
                            <td>@(w.RequestNumber ?? ("#"+w.Id))</td>
                            <td>@(workers.TryGetValue(w.WorkerId, out var wn) ? wn : ("#"+w.WorkerId))</td>
                            <td style="text-align:right;font-weight:600">₹@w.Amount.ToString("N2")</td>
                            <td class="small">@(string.IsNullOrWhiteSpace(w.BankDetails) ? "-" : w.BankDetails)</td>
                            <td>@w.RequestedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                            <td><span class="badge bg-@Badge(w.Status)">@w.Status</span>@if(w.Status=="Rejected" && !string.IsNullOrWhiteSpace(w.RejectionReason)){<div class="small text-danger">@w.RejectionReason</div>}</td>
                            <td style="white-space:nowrap">
                                @if (w.Status == "Pending")
                                {
                                    <form asp-action="ApproveWithdrawal" method="post" style="display:inline">
                                        @Html.AntiForgeryToken()<input type="hidden" name="id" value="@w.Id" />
                                        <button class="btn btn-sm btn-success">Approve</button>
                                    </form>
                                    <button class="btn btn-sm btn-danger" onclick="rejWd(@w.Id)">Reject</button>
                                }
                            </td>
                        </tr>
                    }
                    </tbody>
                </table></div>
            }
        </div>
    </div>
</div>
@section Scripts {
<script>
function postForm(url, data){ var f=document.createElement('form'); f.method='post'; f.action=url; for(var k in data){ var i=document.createElement('input'); i.type='hidden'; i.name=k; i.value=data[k]; f.appendChild(i);} var t=document.querySelector('input[name="__RequestVerificationToken"]'); if(t){f.appendChild(t.cloneNode(true));} document.body.appendChild(f); f.submit(); }
function rejWd(id){ var r=prompt("Rejection reason?"); if(r===null) return; postForm("@Url.Action("RejectWithdrawal")", {id:id, reason:r}); }
</script>
}