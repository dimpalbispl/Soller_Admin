@model IEnumerable<SolarPortal.Application.DTOs.SolarRequestDto>
@{
    ViewData["Title"] = "All Projects";
}

<div class="page active">
    <div class="ph">
        <div class="ph-bc">🛡️ Admin / <span>Projects</span></div>
        <div class="ph-title">📊 All Solar Projects</div>
        <div class="ph-sub">Manage all solar connection requests and their status</div>
    </div>

    @if (Model.Any())
    {
        var paidMap  = (Dictionary<int, decimal>)(ViewBag.PaidMap ?? new Dictionary<int, decimal>());
        var sumTotal = Model.Sum(p => p.RequestedAmount);
        var sumPaid  = paidMap.Values.Sum();
        var sumDue   = Math.Max(0, sumTotal - sumPaid);

        <!-- Portfolio summary cards -->
        <div class="g4" style="margin-bottom:14px">
            <div class="sc">
                <div class="sc-label">Total Projects</div>
                <div class="sc-val blue">@Model.Count()</div>
                <div class="sc-sub">All applications</div>
            </div>
            <div class="sc">
                <div class="sc-label">Total Amount</div>
                <div class="sc-val gold">₹@sumTotal.ToString("N0")</div>
                <div class="sc-sub">Across all projects</div>
            </div>
            <div class="sc">
                <div class="sc-label">Total Paid</div>
                <div class="sc-val green">₹@sumPaid.ToString("N0")</div>
                <div class="sc-sub">Cumulative collected</div>
            </div>
            <div class="sc">
                <div class="sc-label">Total Due</div>
                <div class="sc-val red">₹@sumDue.ToString("N0")</div>
                <div class="sc-sub">Outstanding balance</div>
            </div>
        </div>

        <div class="card">
            <div class="ct"><span class="ct-dot"></span>Projects List</div>

            @{
                // Wire up the reusable filter toolbar. Tells the partial which
                // table to attach to and what placeholder to show in the search box.
                ViewData["FilterTableId"]     = "prj-table";
                ViewData["FilterPlaceholder"] = "Search by Member ID, name, city, state, request #...";
            }
            @await Html.PartialAsync("_ReportFilterToolbar")

            <div class="tbl-wrap">
                <table id="prj-table" class="report-table">
                    <thead>
                        <tr>
                            <th>ID</th>
                            <th>Member ID</th>
                            <th>Member Name</th>
                            <th>City / State</th>
                            <th>Request Type</th>
                            <th>Connection</th>
                            <th>Package</th>
                            <th style="width:80px">Capacity</th>
                            <th>Stage</th>
                            <th>Approval</th>
                            <th style="text-align:right">Total Amount</th>
                            <th style="text-align:right">Paid</th>
                            <th style="text-align:right">Due</th>
                            <th>Date</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var project in Model.OrderByDescending(p => p.CreatedAt))
                        {
                            var paid = paidMap.TryGetValue(project.Id, out var v) ? v : 0m;
                            var due  = Math.Max(0, project.RequestedAmount - paid);
                            // Friendly activation-mode label (same emoji/text the user
                            // panel uses, so admin and user wording stay consistent).
                            var reqTypeLabel = project.RequestType switch
                            {
                                Domain.Enums.RequestType.WithActivation              => "🔌 With Activation",
                                Domain.Enums.RequestType.OnlySolarWithoutActivation  => "⚡ Without Activation",
                                Domain.Enums.RequestType.AlreadyActiveOnlyRequest    => "✅ Already Active",
                                _ => project.RequestType.ToString()
                            };
                            var dateIso = project.CreatedAt.ToString("yyyy-MM-dd");
                            // data-search packs every value the filter should match against.
                            // Keep lowercased so JS substring check works without case juggling.
                            <tr data-search="@($"{project.UserId} {project.ApplicantName} {project.City} {project.State} {project.RequestNumber} {project.SelectedPlan}".ToLower())"
                                data-date="@dateIso">
                                <td data-label="ID" class="td-b">
                                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"
                                       style="color:var(--accent)">@project.RequestNumber</a>
                                </td>
                                <td data-label="Member ID"><code style="font-size:11px;color:#0d9488">@project.UserId</code></td>
                                <td data-label="Member Name">@project.ApplicantName</td>
                                <td data-label="City / State" style="font-size:12px">
                                    @if (!string.IsNullOrWhiteSpace(project.City) || !string.IsNullOrWhiteSpace(project.State))
                                    {
                                        <div>@project.City</div>
                                        <div style="color:var(--text2);font-size:11px">@project.State</div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">—</span>
                                    }
                                </td>
                                <td data-label="Request Type" style="font-size:12px">@reqTypeLabel</td>
                                <td data-label="Connection">@project.ConnectionType</td>
                                <td data-label="Package" style="font-size:12px;max-width:160px" title="@project.SelectedPlan">
                                    @(string.IsNullOrWhiteSpace(project.SelectedPlan) ? "—" : project.SelectedPlan)
                                </td>
                                <td data-label="Capacity">@project.KVCapacity kV</td>
                                <td data-label="Stage">
                                    <span class="sts @GetStageClass(project.CurrentStage)">
                                        @project.CurrentStage.ToString().Replace("_", " ")
                                    </span>
                                </td>
                                <td data-label="Approval">
                                    <span class="sts @GetStatusClass(project.ApprovalStatus)">
                                        @project.ApprovalStatus
                                    </span>
                                </td>
                                <td data-label="Total Amount" style="text-align:right;color:var(--accent);font-weight:600">₹@project.RequestedAmount.ToString("N0")</td>
                                <td data-label="Paid" style="text-align:right;color:var(--green);font-weight:600">₹@paid.ToString("N0")</td>
                                <td data-label="Due" style="text-align:right;color:@(due > 0 ? "var(--danger)" : "var(--green)");font-weight:600">
                                    ₹@due.ToString("N0")
                                    @if (due == 0 && project.RequestedAmount > 0)
                                    {
                                        <small style="display:block;font-size:10px;color:var(--green)">✓ Fully Paid</small>
                                    }
                                </td>
                                <td data-label="Date" style="font-size:12px;color:var(--text2)">@project.CreatedAt.ToString("dd/MM/yyyy")</td>
                                <td data-label="Action">
                                    <a asp-controller="Projects" asp-action="Details" asp-route-id="@project.Id"
                                       class="btn btn-s btn-sm">View</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    else
    {
        <div class="card">
            <div class="ct"><span class="ct-dot"></span>No Projects</div>
            <div style="text-align:center;padding:40px;color:var(--text3)">
                <div style="font-size:48px;margin-bottom:16px">📋</div>
                <div style="font-size:18px;margin-bottom:8px">No projects registered</div>
                <div>Projects will appear here once users submit their applications.</div>
            </div>
        </div>
    }
</div>

@functions {
    string GetStageClass(Domain.Enums.ProjectStatus stage) => stage switch
    {
        Domain.Enums.ProjectStatus.Registration => "sts-pend",
        Domain.Enums.ProjectStatus.ProductSelection => "sts-pend",
        Domain.Enums.ProjectStatus.Payment => "sts-pend",
        Domain.Enums.ProjectStatus.PMSurvey => "sts-pend",
        Domain.Enums.ProjectStatus.MeterDispatch => "sts-act",
        Domain.Enums.ProjectStatus.MaterialDispatch => "sts-act",
        Domain.Enums.ProjectStatus.Installation => "sts-act",
        Domain.Enums.ProjectStatus.DCRUpdate => "sts-act",
        Domain.Enums.ProjectStatus.Completed => "sts-act",
        _ => "sts-pend"
    };

    string GetStatusClass(Domain.Enums.ApprovalStatus status) => status switch
    {
        Domain.Enums.ApprovalStatus.Pending => "sts-pend",
        Domain.Enums.ApprovalStatus.Approved => "sts-act",
        Domain.Enums.ApprovalStatus.Rejected => "sts-rej",
        _ => "sts-pend"
    };
}
