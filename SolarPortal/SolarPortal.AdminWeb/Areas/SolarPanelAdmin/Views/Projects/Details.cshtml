@model SolarPortal.Application.DTOs.SolarRequestDto
@{
    ViewData["Title"] = @Model?.RequestNumber ?? "Project Details";
}

<div class="page active">
    <div class="ph">
        <div class="ph-bc">🛡️ Admin / <a asp-controller="Projects" asp-action="Index" style="color:var(--sun)">Projects</a> / <span>Details</span></div>
        <div class="ph-title">📄 Project @Model?.RequestNumber</div>
        <div class="ph-sub">View and manage this solar connection project</div>
    </div>

    @if (Model != null)
    {
        <div class="g2">
            <!-- Project Info -->
            <div class="card">
                <div class="ct"><span class="ct-dot"></span>Project Information</div>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Request Number</span>
                        <span class="detail-value">@Model.RequestNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Status</span>
                        <span class="detail-value">
                            @{
                                // Per spec: jab project Completed stage pe pahunch jaaye, status
                                // "Approved" dikhna chahiye — "Pending" nahi. Workflow ke last step
                                // (Domestic = DCR, Commercial = Installation) ke baad project
                                // automatically complete + approved maana jaata hai.
                                var effApproval = Model.CurrentStage == Domain.Enums.ProjectStatus.Completed
                                    ? Domain.Enums.ApprovalStatus.Approved
                                    : Model.ApprovalStatus;
                            }
                            <span class="sts @GetStatusClass(effApproval)">@effApproval</span>
                        </span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Current Stage</span>
                        <span class="detail-value">
                            <span class="sts @GetStageClass(Model.CurrentStage)">@Model.CurrentStage.ToString().Replace("_", " ")</span>
                        </span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Connection Type</span>
                        <span class="detail-value">@Model.ConnectionType</span>
                    </div>
                </div>
            </div>

            <!-- Applicant Info -->
            <div class="card">
                <div class="ct"><span class="ct-dot"></span>Applicant Details</div>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Name</span>
                        <span class="detail-value">@Model.ApplicantName</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Mobile</span>
                        <span class="detail-value">@Model.MobileNumber</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Email</span>
                        <span class="detail-value">@Model.Email</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Address</span>
                        <span class="detail-value">@Model.Address, @Model.City, @Model.State @Model.PinCode</span>
                    </div>
                </div>
            </div>

            <!-- Capacity & Amount -->
            <div class="card">
                <div class="ct"><span class="ct-dot"></span>Project Details</div>
                <div class="detail-grid">
                    <div class="detail-item">
                        <span class="detail-label">Capacity</span>
                        <span class="detail-value">@Model.KVCapacity kV</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Requested Amount</span>
                        <span class="detail-value gold">₹@Model.RequestedAmount.ToString("N0")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Approved Amount</span>
                        <span class="detail-value green">₹@Model.ApprovedAmount.ToString("N0")</span>
                    </div>
                    <div class="detail-item">
                        <span class="detail-label">Submitted On</span>
                        <span class="detail-value">@Model.CreatedAt.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            <!-- Documents -->
            @if (Model.Documents.Any())
            {
                <div class="card">
                    <div class="ct"><span class="ct-dot"></span>Attached Documents (@Model.Documents.Count)</div>
                    <div style="max-height:300px;overflow-y:auto">
                        @foreach (var doc in Model.Documents)
                        {
                                <div style="padding:12px;border-bottom:1px solid var(--border);display:flex;justify-content:space-between;align-items:center">
                                    <div>
                                        <div style="font-size:12px">@doc.DocumentType</div>
                                        <div style="color:var(--text2);font-size:11px">@doc.FileName</div>
                                    </div>
                                    <a href="javascript:void(0)" onclick="openFileModal('@doc.FilePath')" class="btn btn-s btn-sm">
                                        📥 View
                                    </a>
                                </div>
                        }
                    </div>
                </div>
            }

            @* === Approve / Reject buttons REMOVED per spec ===
               "is page se approve reject remove kr do approve reject only payment
                verification se honga project ka"
               Approve / Reject buttons are gone from Project Details. The single
               approval entry-point is the Payment Verification screen — that is
               where admin verifies each user payment, and stage advances to
               PM Surya Ghar only when verified total reaches the project amount.

               We keep an "Update Stage" affordance only for already-approved
               projects mid-flight (e.g. ops admin needs to flip Meter Dispatch
               manually). When a project is Rejected we just show a status banner.
            *@
            <div class="card">
                <div class="ct"><span class="ct-dot"></span>Status</div>
                @if (Model.CurrentStage == Domain.Enums.ProjectStatus.Completed)
                {
                    <div class="alert alert-s" style="margin:0">
                        <span class="ai">✅</span>
                        Project complete — all workflow steps finished. No further action needed.
                    </div>
                }
                else if (Model.ApprovalStatus == Domain.Enums.ApprovalStatus.Rejected)
                {
                    <div class="alert alert-d" style="margin:0">
                        <span class="ai">❌</span>
                        This project was rejected. The user must re-submit.
                    </div>
                }
                else if (Model.ApprovalStatus == Domain.Enums.ApprovalStatus.Approved &&
                         Model.CurrentStage != Domain.Enums.ProjectStatus.Completed)
                {
                    <div class="alert alert-i" style="margin:0 0 8px 0">
                        <span class="ai">✓</span>
                        Project approved (via Payment Verification). Currently at stage <strong>@Model.CurrentStage.ToString().Replace("_", " ")</strong>.
                    </div>
                    <div class="btn-row">
                        <button class="btn btn-p" onclick="updateStage(@Model.Id)">📊 Update Stage</button>
                    </div>
                    <div class="hint" style="margin-top:8px;color:var(--text2);font-size:12px">
                        Use Payment Verification to approve / reject payments. Stage override is for operations corrections only.
                    </div>
                }
                else
                {
                    <div class="alert alert-w" style="margin:0">
                        <span class="ai">💰</span>
                        This request will be approved automatically once the user submits payment and admin verifies it in
                        <a asp-controller="Payments" asp-action="Index" style="color:var(--accent);font-weight:600">Payment Verification</a>.
                    </div>
                }
            </div>
        </div>

        <!-- Status Flow -->
        <div class="card" style="margin-top:20px">
            <div class="ct"><span class="ct-dot"></span>Project Status Flow</div>
            <partial name="~/Views/Shared/_StatusFlow.cshtml" model="(int)Model.CurrentStage" />
        </div>
    }
    else
    {
        <div class="card">
            <div style="text-align:center;padding:40px;color:var(--text3)">Project not found</div>
        </div>
    }
</div>

<style>
.detail-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
    padding: 0;
}

.detail-item {
    display: flex;
    flex-direction: column;
    gap: 8px;
}

.detail-label {
    font-size: 12px;
    color: var(--text2);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.5px;
}

.detail-value {
    font-size: 16px;
    color: var(--text1);
    font-weight: 500;
}

.detail-value.gold {
    color: var(--sun);
}

.detail-value.green {
    color: var(--succ);
}
</style>

@functions {
    string GetStatusClass(Domain.Enums.ApprovalStatus status) => status switch
    {
        Domain.Enums.ApprovalStatus.Pending => "sts-pend",
        Domain.Enums.ApprovalStatus.Approved => "sts-act",
        Domain.Enums.ApprovalStatus.Rejected => "sts-rej",
        _ => "sts-pend"
    };

    string GetStageClass(Domain.Enums.ProjectStatus stage) => stage switch
    {
        Domain.Enums.ProjectStatus.Registration => "sts-pend",
        Domain.Enums.ProjectStatus.ProductSelection => "sts-pend",
        Domain.Enums.ProjectStatus.Payment => "sts-pend",
        Domain.Enums.ProjectStatus.PMSurvey => "sts-pend",
        Domain.Enums.ProjectStatus.MeterDispatch => "sts-act",
        Domain.Enums.ProjectStatus.MaterialDispatch => "sts-act",
        Domain.Enums.ProjectStatus.Installation => "sts-act",
        Domain.Enums.ProjectStatus.DCRUpdate => "sts-act",
        Domain.Enums.ProjectStatus.Completed => "sts-act",
        _ => "sts-pend"
    };
}

@section Scripts {
    <script>
        // approveProject() and rejectProject() removed in Round 4 — the only
        // approval entry-point is now the Payment Verification screen
        // (PaymentsController.Verify / .Reject). Solar request approval
        // auto-derives from cumulative verified payment reaching the project amount.

        function updateStage(id) {
            Swal.fire({
                title: 'Override Project Stage',
                text: 'Select the stage to set this project to',
                input: 'select',
                inputOptions: {
                    '1': 'Registration',
                    '2': 'Product Selection',
                    '3': 'Payment',
                    '4': 'PM Survey',
                    '5': 'Meter Dispatch',
                    '7': 'Material Dispatch',
                    '8': 'Installation',
                    '9': 'DCR Update',
                    '10': 'Completed'
                },
                showCancelButton: true,
                confirmButtonText: 'Update Stage',
                background: '#ffffff',
                color: '#1f2937'
            }).then(result => {
                if (result.isConfirmed && result.value) {
                    const fd = new FormData();
                    fd.append('Id', id);
                    fd.append('NewStage', result.value);
                    const token = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (token) fd.append('__RequestVerificationToken', token.value);

                    fetch('/SolarPanelAdmin/Projects/UpdateStage', { method: 'POST', body: fd })
                        .then(r => r.json())
                        .then(d => {
                            if (d.success) {
                                Swal.fire('Updated', 'Stage updated successfully', 'success').then(() => location.reload());
                            } else {
                                Swal.fire('Error', d.message || 'Failed', 'error');
                            }
                        });
                }
            });
        }
    </script>
}

@* In-page file preview modal (no new tab) *@
@await Html.PartialAsync("_FileModal")
