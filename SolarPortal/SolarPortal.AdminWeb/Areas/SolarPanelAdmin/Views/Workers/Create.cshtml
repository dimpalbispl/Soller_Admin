@model SolarPortal.Application.DTOs.CreateWorkerDto
@{
    ViewData["Title"] = "Add Worker";
}

<div class="page active">
    <div class="ph">
        <div class="ph-bc">🛡️ Admin / <a asp-controller="Workers" asp-action="Index" style="color:var(--sun)">Workers</a> / <span>Add</span></div>
        <div class="ph-title">➕ Add New Worker</div>
        <div class="ph-sub">Register a new field worker to the system</div>
    </div>

    <div class="card" style="max-width:600px;margin:20px auto">
        <div class="ct"><span class="ct-dot"></span>Worker Details</div>
        
        <form asp-controller="Workers" asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            
            <div class="fr">
                <div class="fg">
                    <label asp-for="Name">Full Name <span class="req">*</span></label>
                    <input asp-for="Name" placeholder="Worker name" required />
                    <span asp-validation-for="Name" class="text-danger hint"></span>
                </div>
                <div class="fg">
                    <label asp-for="MobileNumber">Mobile Number <span class="req">*</span></label>
                    <input asp-for="MobileNumber" type="tel" placeholder="9800000000" maxlength="10" required />
                    <span asp-validation-for="MobileNumber" class="text-danger hint"></span>
                </div>
            </div>

            <div class="fr">
                <div class="fg">
                    <label asp-for="Type">Worker Type <span class="req">*</span></label>
                    <select asp-for="Type" required>
                        <option value="1">JOB (Salaried / Direct)</option>
                        <option value="2">INC (Incentive / Commission based)</option>
                    </select>
                    <span class="hint">INC = earns per-connection commission. JOB = salaried.</span>
                </div>
                <div class="fg">
                    <label asp-for="Email">Email</label>
                    <input asp-for="Email" type="email" placeholder="worker@example.com" />
                </div>
            </div>
            <div class="fr">
                <div class="fg">
                    <label asp-for="City">City <span class="req">*</span></label>
                    <input asp-for="City" placeholder="Jaipur" required />
                    <span asp-validation-for="City" class="text-danger hint"></span>
                </div>
                <div class="fg">
                    <label asp-for="State">State <span class="req">*</span></label>
                    @{
                        // States from legacy M_StateDivMaster (loaded by controller),
                        // same as the user panel. Value = StateName, data-code = StateCode.
                        var stateList = ViewBag.States
                            as List<SolarPortal.Application.Services.StateDto>
                            ?? new List<SolarPortal.Application.Services.StateDto>();
                    }
                    <select asp-for="State" required>
                        <option value="">Select</option>
                        @foreach (var st in stateList)
                        {
                            <option value="@st.StateName" data-code="@st.StateCode">@st.StateName</option>
                        }
                    </select>
                    <span asp-validation-for="State" class="text-danger hint"></span>
                </div>
            </div>

            @* Removed per spec:
                 - "Specialization" dropdown (was on this form line 42-53)
                 - "Available for Assignment" checkbox (was on this form line 73-79)
               Specialization is no longer captured; IsAvailable is set to true by default
               in the DTO and can be toggled from the worker list if needed. *@

            <div class="btn-row" style="justify-content:space-between;margin-top:20px;border-top:1px solid var(--border);padding-top:20px">
                <a asp-controller="Workers" asp-action="Index" class="btn btn-d">← Cancel</a>
                <button type="submit" class="btn btn-primary">✓ Add Worker</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
