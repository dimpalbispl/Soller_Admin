@{
    ViewData["Title"] = "PM Surya Ghar Review";
    var req = (SolarPortal.Domain.Entities.SolarRequest)ViewBag.Request;
    // Materialize once so Razor's multiple .Any() / .All() / @foreach passes don't
    // re-iterate the underlying query.
    var docs = ((IEnumerable<SolarPortal.Application.DTOs.PMDocumentDto>)ViewBag.Documents).ToList();
}

<div class="page-header" style="padding:16px">
    <h2>PM Surya Ghar — @req.RequestNumber</h2>
    <p class="text-muted">@req.ApplicantName · @req.MobileNumber · @req.City, @req.State</p>
</div>

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Uploaded Documents (@docs.Count)</div>
                <div class="card-body">
                    @if (!docs.Any())
                    {
                        <div class="alert alert-warning mb-3" style="font-size:13px">
                            ⏳ <strong>No documents uploaded yet.</strong> The user must upload
                            their PM Surya Ghar documents before this project can be approved.
                        </div>
                    }
                    else
                    {
                    <div class="tbl-wrap">
                    <table class="table report-table">
                        <thead>
                            <tr>
                                <th>Type</th>
                                <th>File</th>
                                <th>Status</th>
                                <th>Remarks</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var d in docs)
                        {
                            <tr id="row-@d.Id">
                                <td data-label="Type">@d.DocumentType</td>
                                <td data-label="File"><a href="javascript:void(0)" onclick="openFileModal('@d.FilePath')" style="color:#0d9488">@d.FileName</a></td>
                                <td data-label="Status">
                                    <span class="badge bg-@(d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Approved ? "success" : d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Rejected ? "danger" : "warning")">
                                        @d.Status
                                    </span>
                                </td>
                                <td data-label="Remarks">@d.Remarks</td>
                                <td data-label="Actions">
                                    @if (d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Pending)
                                    {
                                        <button class="btn btn-sm btn-success btn-approve" data-id="@d.Id">Approve</button>
                                        <button class="btn btn-sm btn-danger btn-reject"   data-id="@d.Id">Reject</button>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                    </div>
                    }
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            @{
                // 4-state right card. Mutually exclusive:
                //   1. NO DOCS               — yellow waiting banner, button hidden
                //   2. ALL DOCS REJECTED     — red "all rejected" banner, button hidden
                //   3. ALREADY APPROVED      — green status, button hidden
                //   4. APPROVE & ADVANCE     — green action card with button
                // Server (ApproveAndAdvance) blocks states 1-3 too — this just hides
                // the button so admin doesn't accidentally click on an invalid state.
                var stage = req.CurrentStage;
                var advancedPastPMSurvey =
                    stage == SolarPortal.Domain.Enums.ProjectStatus.MeterDispatch ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.SiteSurvey ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.MaterialDispatch ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.Installation ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.DCRUpdate ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.Completed;

                var anyDocs = docs.Any();
                var anyUsable = docs.Any(d => d.Status != SolarPortal.Domain.Enums.ApprovalStatus.Rejected);
                var allDocsApproved = anyDocs &&
                    docs.All(d => d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Approved);

                var alreadyApproved = advancedPastPMSurvey || allDocsApproved;
            }

            @if (alreadyApproved)
            {
                <div class="card border-success">
                    <div class="card-header bg-success text-white">✓ Already Approved</div>
                    <div class="card-body">
                        <p class="mb-2">
                            All PM Surya Ghar documents are <strong>approved</strong>.
                            @if (advancedPastPMSurvey)
                            {
                                <span>Project has advanced to <strong>@stage.ToString().Replace("_", " ")</strong>.</span>
                            }
                            else
                            {
                                <span>You can now move it to <strong>Meter Dispatch</strong> from the workflow.</span>
                            }
                        </p>
                        <p class="text-muted small mb-2">No further action allowed on this page.</p>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">← Back to PM Surya list</a>
                    </div>
                </div>
            }
            else if (!anyDocs)
            {
                @* Bug fix: when no documents are uploaded, do NOT show the approve
                   button. Earlier the green "Approve All & Move to Meter Dispatch"
                   button was visible even with zero uploads, which would silently
                   advance the project. *@
                <div class="card border-warning">
                    <div class="card-header bg-warning" style="color:#7c2d12">⏳ Awaiting User Upload</div>
                    <div class="card-body">
                        <p class="mb-2">
                            The user has <strong>not uploaded any PM Surya Ghar documents yet</strong>.
                            The project cannot advance until at least one valid document is uploaded by the user.
                        </p>
                        <p class="text-muted small mb-3">
                            You'll be able to verify documents and advance to Meter Dispatch once the user submits them.
                        </p>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">← Back to PM Surya list</a>
                    </div>
                </div>
            }
            else if (!anyUsable)
            {
                @* All uploaded documents are rejected — user must re-upload. *@
                <div class="card border-danger">
                    <div class="card-header bg-danger text-white">✕ All Documents Rejected</div>
                    <div class="card-body">
                        <p class="mb-2">
                            All uploaded documents have been <strong>rejected</strong>. The project cannot
                            advance until the user submits corrected documents.
                        </p>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">← Back to PM Surya list</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-success text-white">Approve &amp; Advance</div>
                    <div class="card-body">
                        <p>Once all documents are valid, approve the whole batch and move the project to <strong>Meter Dispatch</strong>.</p>
                        <textarea id="advanceNotes" class="form-control mb-2" placeholder="Optional notes"></textarea>
                        <button id="btnAdvance" class="btn btn-success w-100">Approve All &amp; Move to Meter Dispatch</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
const token = $('input[name="__RequestVerificationToken"]').val();

$('.btn-approve').on('click', function () {
    const id = $(this).data('id');
    $.post('@Url.Action("ApproveDocument")', { docId: id, __RequestVerificationToken: token }, function (r) {
        if (r.success) { alert(r.message); location.reload(); }
    });
});
$('.btn-reject').on('click', function () {
    const id = $(this).data('id');
    const remarks = prompt('Rejection reason?');
    if (remarks === null) return;
    $.post('@Url.Action("RejectDocument")', { docId: id, remarks: remarks, __RequestVerificationToken: token }, function (r) {
        if (r.success) { alert(r.message); location.reload(); }
    });
});

$('#btnAdvance').on('click', function () {
    // Button only exists when alreadyApproved is false (see view). If it
    // doesn't exist on the page, jQuery's .on no-ops silently — harmless.
    if (!confirm('Approve all PM Surya Ghar docs and move this project to Meter Dispatch?')) return;
    $(this).prop('disabled', true).text('Approving…');
    $.post('@Url.Action("ApproveAndAdvance")',
        { requestId: @req.Id, notes: $('#advanceNotes').val(), __RequestVerificationToken: token },
        function (r) {
            alert(r.message);
            if (r.success) window.location.href = '@Url.Action("Index")';
            else $('#btnAdvance').prop('disabled', false).text('Approve All & Move to Meter Dispatch');
        }).fail(function () {
            alert('Server error. Please refresh and try again.');
            $('#btnAdvance').prop('disabled', false).text('Approve All & Move to Meter Dispatch');
        });
});
</script>
}

@* In-page file preview modal (no new tab) *@
@await Html.PartialAsync("_FileModal")
