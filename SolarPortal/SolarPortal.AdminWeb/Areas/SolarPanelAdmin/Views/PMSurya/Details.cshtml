@{
    ViewData["Title"] = "PM Surya Ghar Review";
    var req = (SolarPortal.Domain.Entities.SolarRequest)ViewBag.Request;
    var docs = (IEnumerable<SolarPortal.Application.DTOs.PMDocumentDto>)ViewBag.Documents;
}

<div class="page-header" style="padding:16px">
    <h2>PM Surya Ghar — @req.RequestNumber</h2>
    <p class="text-muted">@req.ApplicantName · @req.MobileNumber · @req.Email · @req.City, @req.State</p>
</div>

<div class="container-fluid">
    <div class="row g-3">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header">Uploaded Documents</div>
                <div class="card-body">
                    @if (!docs.Any())
                    {
                        <p class="text-muted">No documents uploaded yet.</p>
                    }
                    <table class="table">
                        <thead>
                            <tr><th>Type</th><th>File</th><th>Status</th><th>Remarks</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var d in docs)
                        {
                            <tr id="row-@d.Id">
                                <td>@d.DocumentType</td>
                                <td><a href="javascript:void(0)" onclick="openFileModal('@d.FilePath')" style="color:#0d9488">@d.FileName</a></td>
                                <td>
                                    <span class="badge bg-@(d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Approved ? "success" : d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Rejected ? "danger" : "warning")">
                                        @d.Status
                                    </span>
                                </td>
                                <td>@d.Remarks</td>
                                <td>
                                    @if (d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Pending)
                                    {
                                        <button class="btn btn-sm btn-success btn-approve" data-id="@d.Id">Approve</button>
                                        <button class="btn btn-sm btn-danger btn-reject"   data-id="@d.Id">Reject</button>
                                    }
                                </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            @{
                // Per spec: agar saare documents approve ho gaye aur project
                // stage PMSurvey ke aage badh chuka hai, to "Approve All" button
                // nahi dikhna chahiye — sirf "Already Approved" status dikhe.
                //
                // Two conditions for "already advanced":
                //   (a) Stage is past PMSurvey (MeterDispatch, SiteSurvey, etc.) — workflow moved on
                //   (b) All uploaded docs are approved AND there's at least one doc — batch done
                //
                // If only some docs are approved (mixed pending), keep the
                // Approve & Advance card visible so admin can finish the batch.
                var stage = req.CurrentStage;
                var advancedPastPMSurvey =
                    stage == SolarPortal.Domain.Enums.ProjectStatus.MeterDispatch ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.SiteSurvey ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.MaterialDispatch ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.Installation ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.DCRUpdate ||
                    stage == SolarPortal.Domain.Enums.ProjectStatus.Completed;

                var allDocsApproved = docs.Any() &&
                    docs.All(d => d.Status == SolarPortal.Domain.Enums.ApprovalStatus.Approved);

                var alreadyApproved = advancedPastPMSurvey || allDocsApproved;
            }

            @if (alreadyApproved)
            {
                <div class="card border-success">
                    <div class="card-header bg-success text-white">✓ Already Approved</div>
                    <div class="card-body">
                        <p class="mb-2">
                            All PM Surya Ghar documents are <strong>approved</strong>.
                            @if (advancedPastPMSurvey)
                            {
                                <span>Project has advanced to <strong>@stage.ToString().Replace("_", " ")</strong>.</span>
                            }
                            else
                            {
                                <span>You can now move it to <strong>Meter Dispatch</strong> from the workflow.</span>
                            }
                        </p>
                        <p class="text-muted small mb-2">No further action allowed on this page.</p>
                        <a asp-action="Index" class="btn btn-outline-secondary w-100">← Back to PM Surya list</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card">
                    <div class="card-header bg-success text-white">Approve &amp; Advance</div>
                    <div class="card-body">
                        <p>Verify all documents, then enter the PM Surya Ghar ID and (optionally) attach the approval document(s) the user can download. Approval opens <strong>Meter Dispatch</strong> &amp; <strong>Site Survey</strong> together. The user's mobile and email are shown at the top for quick contact.</p>
                        <label class="form-label mb-1">PM Surya Ghar ID No.</label>
                        <input id="pmAppNo" class="form-control mb-2" placeholder="e.g., RJ-PMSG-2026-000123" value="@(req.PmSuryaApplicationNo ?? "")" />
                        <label class="form-label mb-1">Approval Document(s) — user downloadable</label>
                        <input id="approvalDocs" type="file" class="form-control mb-2" multiple accept=".pdf,.png,.jpg,.jpeg" />
                        <textarea id="advanceNotes" class="form-control mb-2" placeholder="Optional notes"></textarea>
                        <button id="btnAdvance" class="btn btn-success w-100">Approve All &amp; Open Meter Dispatch + Site Survey</button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
<script>
const token = $('input[name="__RequestVerificationToken"]').val();

$('.btn-approve').on('click', function () {
    const id = $(this).data('id');
    $.post('@Url.Action("ApproveDocument")', { docId: id, __RequestVerificationToken: token }, function (r) {
        // global toast shows r.message; just reload after a short delay
        if (r.success) { setTimeout(function () { location.reload(); }, 600); }
    });
});
$('.btn-reject').on('click', function () {
    const id = $(this).data('id');
    const remarks = prompt('Rejection reason?');
    if (remarks === null) return;
    $.post('@Url.Action("RejectDocument")', { docId: id, remarks: remarks, __RequestVerificationToken: token }, function (r) {
        if (r.success) { setTimeout(function () { location.reload(); }, 600); }
    });
});

$('#btnAdvance').on('click', function () {
    if (!confirm('Approve all PM Surya Ghar docs and open Meter Dispatch + Site Survey?')) return;
    $(this).prop('disabled', true).text('Approving…');

    var fd = new FormData();
    fd.append('requestId', @req.Id);
    fd.append('notes', $('#advanceNotes').val());
    fd.append('pmSuryaApplicationNo', $('#pmAppNo').val());
    fd.append('__RequestVerificationToken', token);
    var files = document.getElementById('approvalDocs').files;
    for (var i = 0; i < files.length; i++) { fd.append('approvalDocs', files[i]); }

    $.ajax({
        url: '@Url.Action("ApproveAndAdvance")',
        type: 'POST',
        data: fd,
        processData: false,
        contentType: false
    }).done(function (r) {
        // NOTE: the global ajaxSuccess handler in _Toasts.cshtml already shows
        // r.message (success/error). Do NOT alert() here or it shows twice.
        if (r.success) {
            setTimeout(function () { window.location.href = '@Url.Action("Index")'; }, 600);
        } else {
            $('#btnAdvance').prop('disabled', false).text('Approve All & Open Meter Dispatch + Site Survey');
        }
    }).fail(function () {
        // global ajaxError handler shows the error toast
        $('#btnAdvance').prop('disabled', false).text('Approve All & Open Meter Dispatch + Site Survey');
    });
});
</script>
}

@* In-page file preview modal (no new tab) *@
@await Html.PartialAsync("_FileModal")
