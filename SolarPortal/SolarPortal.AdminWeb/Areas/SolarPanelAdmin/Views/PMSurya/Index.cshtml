@model IEnumerable<SolarPortal.Domain.Entities.SolarRequest>
@{
    ViewData["Title"] = ViewBag.Title;
}

<div class="page-header" style="padding:16px">
    <h2>PM Surya Ghar Verification</h2>
    <p class="text-muted">Requests awaiting PM Surya Ghar document verification.</p>
</div>

<div class="container-fluid">
    @{
        var pmFilter = (ViewBag.Filter as string) ?? "pending";
    }
    <div class="mb-3">
        <a class="btn @(pmFilter == "pending" ? "btn-warning" : "btn-outline-warning")"
           asp-action="Index" asp-route-filter="pending">⏳ Pending</a>
        <a class="btn @(pmFilter == "approved" ? "btn-success" : "btn-outline-success")"
           asp-action="Index" asp-route-filter="approved">✅ Approved (history)</a>
        <a class="btn @(pmFilter == "all" ? "btn-primary" : "btn-outline-primary")"
           asp-action="Index" asp-route-filter="all">📋 All</a>
    </div>

    <div class="card">
        <div class="card-body">
            <table class="table table-hover" id="pmTable">
                <thead>
                    <tr>
                        <th>Request #</th>
                        <th>Applicant</th>
                        <th>Plan</th>
                        <th>City / State</th>
                        <th>Connection</th>
                        <th>Submitted</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td><strong>@r.RequestNumber</strong></td>
                        <td>@r.ApplicantName<br /><small class="text-muted">@r.MobileNumber</small></td>
                        <td>@r.SelectedPlan<br /><small class="text-muted">@r.KVCapacity kV</small></td>
                        <td>@r.City, @r.State</td>
                        <td><span class="badge bg-info">@r.ConnectionType</span></td>
                        <td>@r.CreatedAt.ToLocalTime().ToString("dd MMM yyyy")</td>
                        <td>
                            <a class="btn btn-sm btn-primary" asp-action="Details" asp-route-id="@r.Id">Review</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted">No requests pending PM Surya Ghar verification.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
